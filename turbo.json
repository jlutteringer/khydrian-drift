{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [".next/**", "dist/**"]
    },
    "docgen": {
      "outputs": ["docs/**"]
    },
    "clean": {
      "cache": false
    }
  }
}