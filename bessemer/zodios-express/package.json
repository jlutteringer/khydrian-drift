{
  "name": "@bessemer/zodios-express",
  "type": "module",
  "version": "0.5.109",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "test": "jest",
    "prettier-fix": "prettier --write .",
    "clean": "rm -rf dist && rm -rf .turbo"
  },
  "dependencies": {
    "@bessemer/zotch": "workspace:*",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4"
  },
  "files": [
    "dist"
  ]
}
